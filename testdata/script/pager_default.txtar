# --paging=always forces the pager even when stdout is not a TTY. With
# PAGER=stub-pager, verify it was invoked and captured stdin bytes.
env PAGER=stub-pager
env STUB_PAGER_LOG=$WORK/.pager.log

exec stripes --color=never --paging=always input.json
exists $WORK/.pager.log
grep -count=1 '^argv: .*stub-pager$' $WORK/.pager.log
grep -count=1 '^stdin-bytes: \d+$' $WORK/.pager.log

-- input.json --
{"hello":"world"}
