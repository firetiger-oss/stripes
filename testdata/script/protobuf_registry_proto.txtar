# Loading a .proto file via --registry and decoding an empty binary
# payload against the resolved message produces zero-field output (no
# fields are set in an empty wire payload).
exec stripes --color=never --registry input.proto --schema test.v1.Foo empty.binpb
cmp stdout expected.txt

-- input.proto --
syntax = "proto3";
package test.v1;

message Foo {
  string name = 1;
}
-- empty.binpb --
-- expected.txt --
